{
  "name": "vantaapi-ranking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "dev:3001": "next dev --hostname 127.0.0.1 --port 3001",
    "preview": "next start --hostname 127.0.0.1 --port 3002",
    "typecheck": "tsc --noEmit --incremental false",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality": "npm run lint && npm run typecheck && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.cjs",
    "security:check": "node scripts/security-check.js",
    "security:regression": "node scripts/security-regression.js",
    "security:repo": "node scripts/repo-security-check.js",
    "security:full": "npm run security:check && npm run security:regression && npm run security:repo && npm run typecheck && npm run lint && npm run build && npm audit --audit-level=high"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "next": "16.2.4",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "speakeasy": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "webpack-obfuscator": "^3.6.1"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.13"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  }
}
