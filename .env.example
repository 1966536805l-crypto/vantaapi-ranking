# JinMing Lab production launch env template.
# Required production database: Postgres only. Do not use MySQL, SQLite, localhost, or a laptop database.
# Use the pooled DATABASE_URL generated by Neon, Supabase, Vercel Postgres, or another managed Postgres provider.
DATABASE_URL="postgresql://jinming_user:replace-with-strong-password@db.example.com:5432/jinming_lab?sslmode=require"
POSTGRES_DB="jinming_lab"
POSTGRES_USER="jinming_user"
POSTGRES_PASSWORD="replace-with-strong-app-password"

# Required in production. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-at-least-32-random-characters"

# Public registration should stay closed unless you deliberately open onboarding.
ENABLE_PUBLIC_REGISTRATION="false"

# Max 7 days. Enterprise baseline defaults to 24h.
AUTH_SESSION_SECONDS="86400"

# Comma-separated canonical hosts accepted by proxy host-header guard.
# Production: keep only canonical public hosts. Local dev may omit this variable or use 127.0.0.1:<port>.
APP_ALLOWED_HOSTS="vantaapi.com,www.vantaapi.com"

# Optional stable sitemap lastmod. Update on real content releases, not every request.
SITEMAP_LASTMOD="2026-05-08T00:00:00.000Z"

# Edge protection mode. Keep normal for users. Switch to elevated or emergency during attacks.
SECURITY_MODE="normal"

# Required for public launch if AI features are visible. Use a server-side provider key only; never expose it to the browser.
AI_API_KEY="replace-with-server-side-ai-provider-token"
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-chat"
AI_TIMEOUT="12000"

# Recommended for public launch when GitHub Repo Analyzer is visible.
# Use a least-privilege GitHub read token to raise public API quota.
GITHUB_READ_TOKEN="replace-with-github-read-token"

# Optional self-hosted/local AI fallback. Works only when the Next.js server can reach Ollama.
# For Vercel, keep this disabled unless OLLAMA_BASE_URL points to your own secured server.
OLLAMA_ENABLED="false"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:3b"
OLLAMA_TIMEOUT="18000"
OLLAMA_API_KEY=""

# Optional low-friction bot protection for login/register only.
# Production requires Turnstile by default; set both values before public launch.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Optional, explicit seed-only admin initialization. No public default admin is created.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_DEMO_USERS="false"
SEED_STUDENT_EMAIL=""
SEED_STUDENT_PASSWORD=""

# Production defaults to requiring Turnstile for login/register unless set to false intentionally.
AUTH_TURNSTILE_REQUIRED="true"

# Recommended for public launch: set REDIS_URL to an Upstash or managed Redis URL.
# Set true or provide REDIS_URL to enable distributed rate limits.
ENABLE_REDIS_RATE_LIMITS="true"
REDIS_RATE_LIMIT_FAIL_CLOSED="true"
REDIS_URL=""

# Required before enabling admin 2FA because TOTP secrets are encrypted at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-chars"
CSRF_SECRET="replace-with-64-hex-chars"

# Keep true for production: admins without 2FA may only access the 2FA setup flow.
ADMIN_2FA_REQUIRED="true"

# C++ online runner must stay disabled unless moved to an isolated worker/sandbox.
ENABLE_CPP_RUNNER="false"
